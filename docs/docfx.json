{
  "metadata": [
    {
      "src": [
        {
          "files": ["**/Fleece.Core.csproj", "**/Fleece.Cli.csproj"],
          "src": "../src"
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "Fleece",
      "_appTitle": "Fleece Documentation",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_gitContribute": {
        "repo": "https://github.com/nick-boey/Fleece",
        "branch": "main",
        "path": "docs"
      }
    },
    "fileMetadata": {
      "_gitContribute": {
        "api/**": {
          "repo": "https://github.com/nick-boey/Fleece",
          "branch": "main",
          "path": "src"
        }
      }
    }
  }
}
